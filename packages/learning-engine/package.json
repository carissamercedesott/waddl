{
  "name": "@waddl/learning-engine",
  "version": "0.1.0",
  "description": "Framework-agnostic logic for Waddl's learning-focused interaction patterns: hint laddering, assistance fading, and a lightweight learner model.",
  "license": "Apache-2.0",
  "author": "Carissa Ott",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/session.test.ts src/concept-detection.test.ts src/analytics.test.ts",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "learning-sciences",
    "scaffolding",
    "adaptive-hints",
    "developer-tools"
  ]
}
