{
  "name": "@waddl/duckling-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Duckling — the Waddl Claude Code plugin (Mental Model Mode) and its session-recording CLI.",
  "license": "Apache-2.0",
  "author": "Carissa Ott",
  "dependencies": {
    "@waddl/learning-engine": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:cli": "esbuild src/cli.ts --bundle --platform=node --target=node18 --format=cjs --outfile=bin/duckling --banner:js='#!/usr/bin/env node' && chmod +x bin/duckling"
  }
}
